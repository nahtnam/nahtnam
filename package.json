{
  "name": "nahtnam",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:web",
    "build:resume": "bun run scripts/build-resume.ts",
    "build:web": "bun run build:resume && bun run --cwd apps/web build:app",
    "convex": "bun --cwd packages/backend convex",
    "dev": "turbo run dev --env-mode=loose",
    "print:worker": "bun --env-file=.env.local run --cwd apps/print-worker start",
    "preview": "turbo run preview --env-mode=loose",
    "seo:preview-og": "bun run scripts/preview-og-images.ts",
    "start": "turbo run start --env-mode=loose",
    "test": "ultracite check && turbo run typecheck test"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-plugin-react-doctor": "^0.7.4",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "ultracite": "7.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.14"
}
