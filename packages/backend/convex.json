{
  "$schema": "node_modules/convex/schemas/convex.schema.json",
  "authKit": {
    "dev": {
      "configure": {
        "redirectUris": ["https://nahtnam.localhost/api/auth/callback"],
        "appHomepageUrl": "https://nahtnam.localhost",
        "corsOrigins": ["https://nahtnam.localhost"]
      },
      "localEnvVars": {
        "WORKOS_CLIENT_ID": "${authEnv.WORKOS_CLIENT_ID}",
        "WORKOS_API_KEY": "${authEnv.WORKOS_API_KEY}",
        "WORKOS_REDIRECT_URI": "https://nahtnam.localhost/api/auth/callback"
      }
    }
  },
  "aiFiles": {
    "enabled": false
  }
}
