{
  "name": "nahtnam",
  "alias": "www.nahtnam.com",
  "type": "static",
  "static": {
    "redirects": [
      {
        "source": "/resume",
        "destination": "/resume.pdf"
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "engines": {
    "node": "^8.0.0"
  },
  "env": {
    "BASE_URL": "https://www.nahtnam.com"
  }
}
